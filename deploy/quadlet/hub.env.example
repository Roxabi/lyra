# hub.env — hub container environment (hub-scoped vars only)
# Copy to ~/.lyra/env/hub.env and fill in values before starting lyra-hub.service.
# chmod 600 ~/.lyra/env/hub.env
#
# Adapter tokens (Telegram, Discord, TTS/STT) do NOT belong here.
# NATS_URL and NATS_NKEY_SEED_PATH are set inline in lyra-hub.container.

# Anthropic API key — required for LLM calls
ANTHROPIC_API_KEY=

# Secret token for the /health endpoint (any random string; keep private)
LYRA_HEALTH_SECRET=

# Health listener port (default 8443; matches PublishPort in lyra-hub.container)
LYRA_HEALTH_PORT=8443

# Optional: override log directory (default: set inline in lyra-hub.container)
# LYRA_LOG_DIR=

# Optional: path to the roxabi-vault directory inside the container
# ROXABI_VAULT_DIR=
