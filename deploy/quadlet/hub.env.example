# hub.env — hub container environment
# Copy to ~/.lyra/env/hub.env before starting lyra-hub.service.
# chmod 600 ~/.lyra/env/hub.env
#
# ADR-054: bot tokens are NO LONGER stored here. Since #417 (auth.db split, March 2026),
# tokens live Fernet-encrypted in ~/.lyra/config.db and are decrypted at runtime via
# ~/.lyra/keyring.key. This file holds only operational vars for the hub container.
#
# NATS_URL and NATS_NKEY_SEED_PATH are set inline in lyra-hub.container.

# Secret token for the /health endpoint (any random string; keep private)
LYRA_HEALTH_SECRET=

# Health listener port (default 8443; matches PublishPort in lyra-hub.container)
LYRA_HEALTH_PORT=8443
