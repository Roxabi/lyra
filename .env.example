# ┌──────────────────────────────────────────────────────────────────────────┐
# │  Lyra .env — environment variables loaded at startup                    │
# │                                                                        │
# │  Hub adapters: Bot tokens (TELEGRAM_TOKEN, DISCORD_TOKEN) are stored   │
# │  encrypted in ~/.lyra/auth.db via:  lyra bot add                       │
# │                                                                        │
# │  Monitoring cron: runs standalone (not via hub), so it needs            │
# │  TELEGRAM_TOKEN + ANTHROPIC_API_KEY + TELEGRAM_ADMIN_CHAT_ID here.     │
# └──────────────────────────────────────────────────────────────────────────┘

# --- Voice & Audio ---
# LYRA_STT_ENABLED=1                    # enable NATS STT adapter (set to 1 to activate)
# LYRA_STT_MODEL=large-v3-turbo         # faster-whisper model: tiny | small | medium | large-v3-turbo
# LYRA_TTS_ENABLED=1                    # enable NATS TTS adapter (set to 1 to activate)
# LYRA_TTS_ENGINE=qwen-fast             # TTS engine: qwen-fast | qwen | chatterbox | chatterbox-turbo
# LYRA_TTS_VOICE=                       # override default voice (engine-specific)
# LYRA_TTS_LANGUAGE=                    # override default language
# TTS_ENGINE=                           # DEPRECATED — use LYRA_TTS_ENGINE
# STT_MODEL_SIZE=                       # DEPRECATED — use LYRA_STT_MODEL
# LYRA_AUDIO_TMP=                       # custom tmp dir for audio files (must be writable)
# LYRA_MAX_AUDIO_BYTES=5242880          # max audio upload size (default: 5 MB)
# LYRA_STT_TIMEOUT=15.0                 # STT NATS request timeout in seconds (default: 15.0)

# --- Monitoring (systemd timer: lyra-monitor.timer) ---
# The cron runs standalone — it sends alerts via Telegram Bot API directly.
TELEGRAM_TOKEN=                         # bot token for sending monitoring alerts (same bot or dedicated)
TELEGRAM_ADMIN_CHAT_ID=                 # numeric chat ID for monitoring alerts
# ANTHROPIC_API_KEY=                    # optional — only needed if `claude` CLI is not installed
# LYRA_HEALTH_SECRET=                   # bearer token for /health endpoint (leave empty to disable auth)
# LYRA_CONFIG_SECRET=                   # bearer token for /config endpoint

# --- Deployment target — used by `make deploy` and `make remote` ---
DEPLOY_HOST=                            # SSH user@host for production hub (e.g. user@192.168.1.16)
DEPLOY_DIR=~/projects/lyra             # project path on the production host

# --- LLM (hub — only if using SDK backend instead of claude-cli) ---
# ANTHROPIC_API_KEY is set in Monitoring section above; hub uses it too if SDK backend is enabled

# --- Paths (all optional, sensible defaults) ---
# LYRA_CONFIG=config.toml              # path to config.toml (default: config.toml in cwd)
# LYRA_MESSAGES_CONFIG=                 # path to custom messages.toml
# LYRA_VAULT_DIR=                       # credential vault dir (default: ~/.lyra)
# ROXABI_VAULT_DIR=                     # roxabi-vault dir (default: ~/.roxabi-vault)

# --- NATS (standalone hub/adapter mode) ---
# NATS_URL=nats://localhost:4222          # NATS server URL (required for standalone mode)

# --- NATS authentication (production only) ---
# NATS_NKEY_SEED_PATH=/etc/nats/nkeys/hub.seed   # path to nkey seed file (unset = no auth, for local dev)
