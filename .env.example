# ┌──────────────────────────────────────────────────────────────────────────┐
# │  Lyra .env — environment variables loaded at startup via python-dotenv  │
# │                                                                        │
# │  Bot tokens (TELEGRAM_TOKEN, DISCORD_TOKEN, etc.) do NOT go here.      │
# │  They are stored encrypted in ~/.lyra/auth.db via:  lyra bot add       │
# └──────────────────────────────────────────────────────────────────────────┘

# --- Voice & Audio ---
TTS_ENGINE=qwen-fast                    # TTS engine: qwen-fast | qwen | chatterbox | chatterbox-turbo
# TTS_VOICE=                            # override default voice (engine-specific)
# TTS_LANGUAGE=                         # override default language
STT_MODEL_SIZE=large-v3-turbo           # faster-whisper model: tiny | small | medium | large-v3-turbo
# LYRA_VOICE_RESPONSES=1               # enable voice responses (set to 0 to disable)
# LYRA_AUDIO_TMP=                       # custom tmp dir for audio files (must be writable)
# LYRA_MAX_AUDIO_BYTES=5242880          # max audio upload size (default: 5 MB)

# --- Monitoring ---
# LYRA_HEALTH_SECRET=                   # bearer token for /health endpoint (leave empty to disable auth)
# LYRA_CONFIG_SECRET=                   # bearer token for /config endpoint
# TELEGRAM_ADMIN_CHAT_ID=              # numeric chat ID for monitoring alerts via Telegram

# --- Machine 1 (Hub) — used by `make deploy` from Machine 2 ---
MACHINE1_HOST=mickael@192.168.1.16
MACHINE1_DIR=~/projects/lyra

# --- LLM (only if using SDK backend instead of claude-cli) ---
# ANTHROPIC_API_KEY=                    # not needed if using claude-cli backend (default)

# --- Paths (all optional, sensible defaults) ---
# LYRA_CONFIG=config.toml              # path to config.toml (default: config.toml in cwd)
# LYRA_MESSAGES_CONFIG=                 # path to custom messages.toml
# LYRA_VAULT_DIR=                       # credential vault dir (default: ~/.lyra)
# ROXABI_VAULT_DIR=                     # roxabi-vault dir (default: ~/.roxabi-vault)

# --- dev-core: GitHub Project V2 (auto-detected by /init) ---
# GITHUB_REPO=owner/repo
# GH_PROJECT_ID=PVT_...
# STATUS_FIELD_ID=PVTSSF_...
# SIZE_FIELD_ID=PVTSSF_...
# PRIORITY_FIELD_ID=PVTSSF_...
# STATUS_OPTIONS_JSON={}
# SIZE_OPTIONS_JSON={}
# PRIORITY_OPTIONS_JSON={}
# GITHUB_TOKEN=                         # falls back to `gh auth token`
