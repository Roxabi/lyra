{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dep-graph layout.json schema (multi-repo)",
  "type": "object",
  "required": ["meta", "lanes", "standalone", "overrides", "extra_deps", "cross_deps", "title_rules"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "date", "repos", "label_prefix"],
      "additionalProperties": false,
      "not": { "required": ["repo"] },
      "properties": {
        "title":        { "type": "string" },
        "date":         { "type": "string", "format": "date" },
        "repos":        { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "label_prefix": { "type": "string", "description": "e.g. graph:" },
        "issue":        { "$ref": "#/$defs/IssueRef" },
        "category":     { "type": "string" },
        "cat_label":    { "type": "string" },
        "color":        { "type": "string" }
      }
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "name", "color", "order"],
        "additionalProperties": false,
        "properties": {
          "code":  { "type": "string" },
          "name":  { "type": "string" },
          "color": { "type": "string" },
          "epic": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "required": ["issue", "label", "tag"],
                "additionalProperties": false,
                "properties": {
                  "issue": { "type": "integer" },
                  "label": { "type": "string" },
                  "tag":   { "type": "string" },
                  "defer": { "type": "boolean" }
                }
              }
            ]
          },
          "order": {
            "type": "array",
            "items": { "$ref": "#/$defs/IssueRef" }
          },
          "par_groups": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "$ref": "#/$defs/IssueRef" }
            }
          },
          "bands": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["before", "text"],
              "additionalProperties": false,
              "properties": {
                "before": { "$ref": "#/$defs/IssueRef" },
                "text":   { "type": "string" }
              }
            }
          }
        }
      }
    },
    "standalone": {
      "type": "object",
      "required": ["order"],
      "additionalProperties": false,
      "properties": {
        "order": {
          "type": "array",
          "items": { "$ref": "#/$defs/IssueRef" }
        }
      }
    },
    "overrides": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[^/]+/[^/]+#\\d+$": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title":          { "type": "string" },
            "size":           { "type": "string" },
            "status":         { "type": "string", "enum": ["done", "ready", "blocked", "defer"] },
            "anchor":         { "type": "string" },
            "anchor_after":   { "type": "string" },
            "extra_deps_ext": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "extra_deps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extra_blocked_by": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[^/]+/[^/]+#\\d+$": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[^/]+/[^/]+#\\d+$" }
            }
          }
        },
        "extra_blocking": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[^/]+/[^/]+#\\d+$": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[^/]+/[^/]+#\\d+$" }
            }
          }
        }
      }
    },
    "cross_deps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "text"],
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "title_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern", "replacement"],
        "additionalProperties": false,
        "properties": {
          "pattern":     { "type": "string" },
          "replacement": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "IssueRef": {
      "type": "object",
      "required": ["repo", "issue"],
      "additionalProperties": false,
      "properties": {
        "repo":  { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "issue": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
