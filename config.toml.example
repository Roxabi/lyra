# config.toml.example — copy to config.toml and fill in your values.
# config.toml is gitignored — never commit it.
#
# ----------------------------------------------------------------------------
# What lives here vs in the DB (~/.lyra/auth.db)
# ----------------------------------------------------------------------------
#
# config.toml is the bootstrap file — only what cannot live in the DB yet:
#   - [defaults]           machine-specific paths
#   - [admin]              admin user IDs
#   - [[*.bots]]           which bots exist and their adapter settings
#   - [[auth.*_bots]]      default trust level + initial owner/trusted grants
#
# Everything else is managed in the DB and does NOT belong here:
#   - Bot tokens / webhook secrets  → `lyra bot add`
#   - Agent ↔ bot assignments       → `lyra agent assign`
#                                      (TOML agent= is a one-time fallback
#                                       if the DB has no mapping yet)
#   - Agent config (prompt, TTS…)   → `lyra agent init` (seeds from TOML)
#   - Per-user trust grants         → `lyra auth grant`
#
# ----------------------------------------------------------------------------

[defaults]
cwd = "~/projects"                      # working directory for agent subprocesses
# workspaces.lyra     = "~/projects/lyra"   # adds /lyra slash command
# workspaces.projects = "~/projects"        # adds /projects slash command

[admin]
# User IDs allowed to run admin commands (/invite, /unpair, etc.)
# Format: "tg:user:<numeric_id>" or "dc:user:<numeric_snowflake>"
# Get Telegram ID: message @userinfobot   Get Discord ID: Settings → Advanced → Developer Mode
user_ids = [
    # "tg:user:123456789",
    # "dc:user:123456789012345678",
]

# ----------------------------------------------------------------------------
# Tool display — controls how tool calls are shown during streaming responses
# All keys are optional; values shown are the defaults.
# ----------------------------------------------------------------------------

[tool_display]
# names_threshold = 3     # named edits to show per file before collapsing to "N edits"
# group_threshold = 3     # files before switching to grouped summary (e.g. "4 files edited")
# bash_max_len    = 60    # max characters shown per bash command before truncating
# throttle_ms     = 2000  # min milliseconds between streaming tool-summary updates (0 = off)

[tool_display.show]
# Per-tool visibility — set to false to silence a tool from the summary card.
# Only the keys listed below are recognised; unknown keys are silently ignored.
# edit       = true
# write      = true
# bash       = true
# web_fetch  = true
# web_search = true
# agent      = true
# read       = false   # silent by default (high-frequency, low signal)
# grep       = false   # silent by default
# glob       = false   # silent by default

# ----------------------------------------------------------------------------
# Telegram bots — one [[telegram.bots]] + [[auth.telegram_bots]] per bot
# ----------------------------------------------------------------------------

[[telegram.bots]]
bot_id = "lyra"                         # must match the bot_id used in `lyra bot add`
# bot_username = "MyLyraBot"            # optional — used in help text (default: "lyra_bot")
# agent = "lyra_default"               # fallback if DB has no bot→agent mapping yet

[[auth.telegram_bots]]
bot_id = "lyra"
default = "blocked"                     # "blocked" | "trusted" | "owner"
owner_users = []                        # numeric Telegram IDs — seeded into DB on startup
# trusted_users = []                    # numeric Telegram IDs with trusted (non-admin) access

# Add more bots by repeating the pair above:
# [[telegram.bots]]
# bot_id = "aryl"
#
# [[auth.telegram_bots]]
# bot_id = "aryl"
# default = "blocked"
# owner_users = []

# ----------------------------------------------------------------------------
# Discord bots — one [[discord.bots]] + [[auth.discord_bots]] per bot
# ----------------------------------------------------------------------------

[[discord.bots]]
bot_id = "lyra"                         # must match the bot_id used in `lyra bot add`
# auto_thread = true                    # optional — thread per conversation (default: true)
# agent = "lyra_default"               # fallback if DB has no bot→agent mapping yet

[[auth.discord_bots]]
bot_id = "lyra"
default = "blocked"                     # "blocked" | "trusted" | "owner"
owner_users = []                        # numeric Discord snowflake IDs — seeded into DB on startup
# trusted_roles = []                    # numeric Discord role snowflake IDs with trusted access

# Add more bots by repeating the pair above:
# [[discord.bots]]
# bot_id = "aryl"
#
# [[auth.discord_bots]]
# bot_id = "aryl"
# default = "blocked"
# owner_users = []
