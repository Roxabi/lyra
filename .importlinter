[importlinter]
root_package = lyra
source_root = src
include_external_packages = True

[importlinter:contract:clean-architecture-layers]
name = Clean architecture layers (core <- llm/nats <- infrastructure <- adapters <- bootstrap)
type = layers
layers =
    lyra.bootstrap
    lyra.adapters
    lyra.infrastructure
    lyra.llm | lyra.nats
    lyra.core
ignore_imports =
    # Dependency inversion: core can reference infrastructure types for type hints
    # (TYPE_CHECKING imports have no runtime dependency)
    lyra.core.hub.hub -> lyra.infrastructure.stores.message_index
    lyra.core.hub.hub -> lyra.infrastructure.stores.turn_store
    lyra.core.hub.hub -> lyra.infrastructure.stores.prefs_store
    lyra.core.hub.hub -> lyra.infrastructure.stores.pairing
    lyra.core.hub.hub -> lyra.infrastructure.stores.identity_alias_store
    lyra.core.pool.pool -> lyra.infrastructure.stores.turn_store
    lyra.core.pool.pool_observer -> lyra.infrastructure.stores.message_index
    lyra.core.pool.pool_observer -> lyra.infrastructure.stores.turn_store
    lyra.core.cli_pool -> lyra.infrastructure.stores.turn_store
    lyra.core.authenticator -> lyra.infrastructure.stores.identity_alias_store
    lyra.core.memory -> lyra.infrastructure.stores.identity_alias_store
    # Factory pattern: make_agent_store() imports implementation at runtime
    lyra.core.stores.agent_store_protocol -> lyra.infrastructure.stores.agent_store
    # Other TYPE_CHECKING imports for type hints (no runtime dependency)
    lyra.core.agent_refiner -> lyra.infrastructure.stores.agent_store
    lyra.core.agent -> lyra.infrastructure.stores.agent_store
    lyra.core.authenticator -> lyra.infrastructure.stores.auth_store

[importlinter:contract:core-stores-no-sqlite]
name = core/stores protocols must not import SQLite drivers
type = forbidden
source_modules =
    lyra.core.stores
forbidden_modules =
    aiosqlite
    sqlite3
# Must keep allow_indirect_imports = true because make_agent_store() factory
# imports AgentStore from infrastructure at runtime (intentional dependency inversion)
allow_indirect_imports = true
