# telegram.env — Telegram adapter container environment (scoped vars only)
# Copy to ~/.lyra/env/telegram.env and fill in values before starting lyra-telegram.service.
# chmod 600 ~/.lyra/env/telegram.env
#
# Hub vars (LYRA_HEALTH_SECRET) do NOT belong here.
# NATS_URL and NATS_NKEY_SEED_PATH are set inline in lyra-telegram.container.

# Telegram bot token from @BotFather — required
TELEGRAM_TOKEN=

# Webhook secret used to validate incoming Telegram updates — required in webhook mode
TELEGRAM_WEBHOOK_SECRET=

# Optional: bot username (used in help text / self-identification; e.g. @MyBotName)
# TELEGRAM_BOT_USERNAME=

# Optional: max audio payload accepted (bytes); default determined by the adapter
# LYRA_MAX_AUDIO_BYTES=

# Optional: temp directory for audio processing inside the container
# LYRA_AUDIO_TMP=
