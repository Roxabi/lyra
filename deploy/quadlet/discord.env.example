# discord.env — Discord adapter container environment (scoped vars only)
# Copy to ~/.lyra/env/discord.env and fill in values before starting lyra-discord.service.
# chmod 600 ~/.lyra/env/discord.env
#
# Hub vars (ANTHROPIC_API_KEY, LYRA_HEALTH_SECRET) do NOT belong here.
# NATS_URL and NATS_NKEY_SEED_PATH are set inline in lyra-discord.container.

# Discord bot token from the Discord developer portal — required
DISCORD_TOKEN=

# Optional: enable automatic thread creation per conversation (true/false)
# DISCORD_AUTO_THREAD=

# Optional: max audio payload accepted (bytes); default determined by the adapter
# LYRA_MAX_AUDIO_BYTES=
