# .env.discord — Discord adapter container environment (scoped vars only)
# Copy to %h/projects/lyra/.env.discord and fill in values.
# NATS_URL and NATS_NKEY_SEED_PATH are set directly in discord.container.
# Hub vars (ANTHROPIC_API_KEY, LYRA_HEALTH_SECRET) do NOT belong here.

DISCORD_TOKEN=

# Optional
# DISCORD_AUTO_THREAD=
# LYRA_MAX_AUDIO_BYTES=
