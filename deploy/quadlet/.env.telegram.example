# .env.telegram — Telegram adapter container environment (scoped vars only)
# Copy to %h/projects/lyra/.env.telegram and fill in values.
# NATS_URL and NATS_NKEY_SEED_PATH are set directly in telegram.container.
# Hub vars (ANTHROPIC_API_KEY, LYRA_HEALTH_SECRET) do NOT belong here.

TELEGRAM_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Optional
# LYRA_AUDIO_TMP=
# LYRA_MAX_AUDIO_BYTES=
